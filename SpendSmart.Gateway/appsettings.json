{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "CorsPolicy": "AllowAngularApp",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "category-route": {
        "ClusterId": "category-cluster",
        "CorsPolicy": "AllowAngularApp",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "expense-route": {
        "ClusterId": "expense-cluster",
        "CorsPolicy": "AllowAngularApp",
        "Match": {
          "Path": "/api/expenses/{**catch-all}"
        }
      },
      "income-route": {
        "ClusterId": "income-cluster",
        "CorsPolicy": "AllowAngularApp",
        "Match": {
          "Path": "/api/incomes/{**catch-all}"
        }
      },
      "budget-route": {
        "ClusterId": "budget-cluster",
        "CorsPolicy": "AllowAngularApp",
        "Match": {
          "Path": "/api/budgets/{**catch-all}"
        }
      },
      "report-route": {
        "ClusterId": "report-cluster",
        "CorsPolicy": "AllowAngularApp",
        "Match": {
          "Path": "/api/reports/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "CorsPolicy": "AllowAngularApp",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "category-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5020"
          }
        }
      },
      "expense-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "income-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "budget-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "report-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5006"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5007"
          }
        }
      }
    }
  }
}
